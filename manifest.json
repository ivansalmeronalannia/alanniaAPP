<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Alannia" />
  <meta name="theme-color" content="#1B6B43" />
  <link rel="manifest" href="manifest.json" />
  <link rel="apple-touch-icon" href="icon.png" />
  <title>Alannia Resorts</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

    :root {
      --green: #1B6B43;
      --green-dark: #0D4A2B;
      --white: #ffffff;
      --serif: 'Cormorant Garamond', Georgia, serif;
      --sans: 'DM Sans', system-ui, sans-serif;
    }

    html, body {
      height: 100%;
      overflow: hidden;
      background: var(--green-dark);
      font-family: var(--sans);
      -webkit-font-smoothing: antialiased;
    }

    #app {
      width: 100%;
      max-width: 430px;
      height: 100dvh;
      margin: 0 auto;
      position: relative;
      overflow: hidden;
      background: var(--green);
    }

    .screen {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s ease;
      will-change: transform;
    }
    .screen.hidden { transform: translateX(100%); opacity: 0; pointer-events: none; }
    .screen.exit   { transform: translateX(-8%); opacity: 0; pointer-events: none; }

    /* HOME */
    #home { background: linear-gradient(168deg, #0D4A2B 0%, #1B6B43 40%, #155535 100%); }

    .home-header { padding: max(env(safe-area-inset-top), 48px) 24px 20px; flex-shrink: 0; }

    .logo-row { display: flex; align-items: flex-end; gap: 10px; margin-bottom: 10px; }
    .logo-main { font-family: var(--serif); font-size: 42px; font-weight: 300; color: var(--white); letter-spacing: 1px; line-height: 1; }
    .logo-badge { font-family: var(--sans); font-size: 9px; font-weight: 300; color: rgba(255,255,255,0.45); letter-spacing: 3.5px; text-transform: uppercase; padding-bottom: 6px; }
    .home-tagline { font-family: var(--serif); font-size: 19px; font-style: italic; color: rgba(255,255,255,0.65); line-height: 1.45; }

    .resort-list { flex: 1; overflow-y: auto; padding: 8px 20px 32px; scrollbar-width: none; }
    .resort-list::-webkit-scrollbar { display: none; }

    .resort-card {
      display: flex; align-items: center; gap: 14px;
      background: rgba(255,255,255,0.07); border: 0.5px solid rgba(255,255,255,0.14);
      border-radius: 18px; padding: 14px 16px; margin-bottom: 10px;
      cursor: pointer; transition: background 0.18s, transform 0.15s;
      animation: fadeUp 0.4s ease both;
    }
    .resort-card:active { background: rgba(255,255,255,0.13); transform: scale(0.985); }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .resort-icon { width: 50px; height: 50px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; border: 1px solid rgba(255,255,255,0.1); }
    .resort-info { flex: 1; min-width: 0; }
    .resort-name { font-family: var(--sans); font-size: 16px; font-weight: 500; color: var(--white); margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .resort-loc { font-size: 12px; color: rgba(255,255,255,0.48); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .resort-chevron { font-size: 22px; color: rgba(255,255,255,0.28); font-weight: 300; flex-shrink: 0; }

    .home-footer { padding: 10px 20px max(env(safe-area-inset-bottom), 16px); text-align: center; flex-shrink: 0; }
    .home-footer span { font-size: 11px; color: rgba(255,255,255,0.2); }

    /* DETAIL */
    #detail { background: var(--green); overflow-y: auto; scrollbar-width: none; }
    #detail::-webkit-scrollbar { display: none; }

    .detail-nav { padding: max(env(safe-area-inset-top), 52px) 20px 0; flex-shrink: 0; }
    .back-btn { display: inline-flex; align-items: center; gap: 5px; font-size: 14px; color: rgba(255,255,255,0.7); cursor: pointer; padding: 6px 0; border: none; background: none; font-family: var(--sans); }
    .back-btn:hover { color: var(--white); }

    .detail-hero { padding: 24px 24px 20px; }
    .detail-emoji { font-size: 60px; margin-bottom: 14px; display: block; }
    .detail-name { font-family: var(--serif); font-size: 44px; font-weight: 400; color: var(--white); line-height: 1.05; margin-bottom: 10px; }
    .detail-tagline { font-family: var(--serif); font-size: 17px; font-style: italic; color: rgba(255,255,255,0.6); margin-bottom: 10px; }
    .detail-location { font-size: 13px; color: rgba(255,255,255,0.48); }

    .detail-desc { padding: 0 24px 20px; font-size: 15px; color: rgba(255,255,255,0.72); line-height: 1.65; }

    .detail-divider { height: 0.5px; background: rgba(255,255,255,0.12); margin: 0 24px 20px; }

    .feat-section { padding: 0 24px 20px; }
    .feat-label { font-size: 10px; letter-spacing: 2.5px; color: rgba(255,255,255,0.35); text-transform: uppercase; margin-bottom: 12px; }
    .feat-grid { display: flex; flex-wrap: wrap; gap: 8px; }
    .feat-chip { display: flex; align-items: center; gap: 7px; background: rgba(255,255,255,0.09); border: 0.5px solid rgba(255,255,255,0.18); border-radius: 10px; padding: 7px 11px; font-size: 12px; color: rgba(255,255,255,0.82); }

    .cta-section { padding: 0 24px max(env(safe-area-inset-bottom), 36px); display: flex; flex-direction: column; gap: 10px; }
    .cta-main { display: block; width: 100%; padding: 15px; border-radius: 14px; background: var(--white); color: #111; font-family: var(--sans); font-size: 15px; font-weight: 600; text-align: center; border: none; cursor: pointer; text-decoration: none; }
    .cta-main:active { opacity: 0.88; }
    .cta-outline { display: block; width: 100%; padding: 14px; border-radius: 14px; background: transparent; color: rgba(255,255,255,0.78); font-family: var(--sans); font-size: 15px; text-align: center; border: 0.5px solid rgba(255,255,255,0.3); cursor: pointer; text-decoration: none; }
    .cta-outline:active { background: rgba(255,255,255,0.08); }

    @media (min-width: 430px) {
      body { background: #0a2e1a; }
      #app { box-shadow: 0 0 80px rgba(0,0,0,0.5); border-radius: 40px; margin-top: max(0px, calc((100dvh - 900px) / 2)); height: min(900px, 100dvh); }
    }
  </style>
</head>
<body>
<div id="app">

  <div id="home" class="screen">
    <div class="home-header">
      <div class="logo-row">
        <span class="logo-main">alannia</span>
        <span class="logo-badge">Resorts</span>
      </div>
      <p class="home-tagline">Elige tu resort y<br>vive la experiencia</p>
    </div>
    <div class="resort-list" id="resort-list"></div>
    <div class="home-footer">
      <span>7 establecimientos &middot; Costa Mediterr&aacute;nea</span>
    </div>
  </div>

  <div id="detail" class="screen hidden">
    <div class="detail-nav">
      <button class="back-btn" onclick="goHome()">&#8249; Todos los resorts</button>
    </div>
    <div class="detail-hero">
      <span class="detail-emoji" id="d-emoji"></span>
      <div class="detail-name" id="d-name"></div>
      <div class="detail-tagline" id="d-tagline"></div>
      <div class="detail-location" id="d-location"></div>
    </div>
    <div class="detail-desc" id="d-desc"></div>
    <div class="detail-divider"></div>
    <div class="feat-section">
      <div class="feat-label">Instalaciones y servicios</div>
      <div class="feat-grid" id="d-feats"></div>
    </div>
    <div class="detail-divider"></div>
    <div class="cta-section">
      <a id="d-cta" class="cta-main" target="_blank">Ir al resort</a>
      <a id="d-map" class="cta-outline" target="_blank">&#128205; Ver en el mapa</a>
    </div>
  </div>

</div>
<script>
var RESORTS = [
  { name:'Costa Blanca', location:'Crevillente, Alicante', tagline:'El resort más completo de Europa', desc:'Piscinas tropicales, toboganes, spa, animación familiar y gastronomía mediterránea en pleno corazón de la Costa Blanca.', color:'#1B6B43', emoji:'🌊', url:'https://acb.alanniaresorts.com/', features:['🏊 Piscinas tropicales','💆 Spa y Wellness','🎭 Animación','🍽️ Restaurante','🐾 Pet friendly','📱 Check-in online'] },
  { name:'Guardamar', location:'Guardamar del Segura, Alicante', tagline:'A orillas del Mediterráneo', desc:'A pocos metros de la playa, piscinas tropicales con toboganes. El lugar perfecto para unas vacaciones en familia.', color:'#1A5C8A', emoji:'🏖️', url:'https://guardamar.alanniaresorts.com/', features:['🏖️ Primera línea de playa','🏊 Piscinas','🎭 Animación','🍽️ Restaurante','🐾 Pet friendly','📶 WiFi'] },
  { name:'Els Prats', location:'Mont-roig del Camp, Tarragona', tagline:'Junto al mar en la Costa Dorada', desc:'Situado en uno de los más bellos parajes de la Costa Dorada, a orillas del Mediterráneo.', color:'#8B3A1D', emoji:'🌅', url:'https://elsprats.alanniaresorts.com/', features:['🌊 Frente al mar','🏊 Piscinas','🎭 Animación','🍽️ Restaurante','🐾 Pet friendly','📶 WiFi'] },
  { name:'Costa Dorada', location:"L'Hospitalet de l'Infant, Tarragona", tagline:'Tranquilidad y calidad junto al mar', desc:'Entorno ideal para unas vacaciones inolvidables a orillas del Mediterráneo entre el mar y la montaña.', color:'#5C3D8A', emoji:'🌿', url:'https://costadorada.alanniaresorts.com/', features:['🏖️ Primera línea','🏊 Piscinas','🎭 Animación','🍽️ Restaurante','🐾 Pet friendly','📶 WiFi'] },
  { name:'Salou', location:'Salou, Tarragona', tagline:'Hotel resort en el corazón de Salou', desc:'Hotel resort en pleno Salou con todas las comodidades para unas vacaciones mediterráneas perfectas.', color:'#1A6B5C', emoji:'🏨', url:'https://salou.alanniaresorts.com/', features:['🏨 Hotel resort','🏊 Piscinas','🎭 Animación','🍽️ Restaurante','🐾 Pet friendly','📶 WiFi'] },
  { name:'El Pinar', location:'Blanes, Girona', tagline:'Entre el pinar y la playa dorada', desc:'Ubicado en un pinar natural a solo 1,6 km de las playas doradas, en el corazón de la Costa Brava.', color:'#2D5C1A', emoji:'🌲', url:'https://elpinar.alanniaresorts.com/', features:['🌲 Pinar natural','🏖️ Playa a 1,6 km','🏊 Piscinas','🎭 Animación','🐾 Pet friendly','📶 WiFi'] },
  { name:'Neptuno', location:'Costa Brava, Girona', tagline:'Enclave único en la Costa Brava', desc:'Enclave único en la Costa Brava con acceso privilegiado al Mediterráneo y todas las comodidades de un resort de primer nivel.', color:'#1A3D8B', emoji:'🔱', url:'https://neptuno.alanniaresorts.com/', features:['⛵ Costa Brava','🏊 Piscinas','🎭 Animación','🍽️ Restaurante','🐾 Pet friendly','📶 WiFi'] }
];

var list = document.getElementById('resort-list');
RESORTS.forEach(function(r, i) {
  var card = document.createElement('div');
  card.className = 'resort-card';
  card.style.animationDelay = (i * 60) + 'ms';
  card.innerHTML = '<div class="resort-icon" style="background:' + r.color + '33">' + r.emoji + '</div><div class="resort-info"><div class="resort-name">' + r.name + '</div><div class="resort-loc">' + r.location + '</div></div><div class="resort-chevron">›</div>';
  card.addEventListener('click', function() { openDetail(r); });
  list.appendChild(card);
});

function openDetail(r) {
  document.getElementById('home').classList.add('exit');
  var detail = document.getElementById('detail');
  detail.style.background = 'linear-gradient(160deg, ' + r.color + ' 0%, ' + darken(r.color, 30) + ' 100%)';
  detail.classList.remove('hidden');
  document.getElementById('d-emoji').textContent = r.emoji;
  document.getElementById('d-name').innerHTML = 'Alannia<br>' + r.name;
  document.getElementById('d-tagline').textContent = r.tagline;
  document.getElementById('d-location').textContent = '📍 ' + r.location;
  document.getElementById('d-desc').textContent = r.desc;
  document.getElementById('d-cta').href = r.url;
  document.getElementById('d-cta').textContent = 'Ir al resort → ' + r.name;
  document.getElementById('d-map').href = 'https://maps.google.com/?q=Alannia+' + encodeURIComponent(r.name);
  document.getElementById('d-feats').innerHTML = r.features.map(function(f) { return '<div class="feat-chip">' + f + '</div>'; }).join('');
  detail.scrollTop = 0;
}

function goHome() {
  document.getElementById('home').classList.remove('exit');
  document.getElementById('detail').classList.add('hidden');
}

function darken(hex, amount) {
  var n = parseInt(hex.replace('#',''), 16);
  var r = Math.max(0, (n >> 16) - amount);
  var g = Math.max(0, ((n >> 8) & 0xff) - amount);
  var b = Math.max(0, (n & 0xff) - amount);
  return '#' + [r,g,b].map(function(x) { return x.toString(16).padStart(2,'0'); }).join('');
}

if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js').catch(function(){});
}
</script>
</body>
</html>
